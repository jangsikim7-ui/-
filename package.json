{
  "name": "poong-synergy",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node --experimental-sqlite --watch server/index.js",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev\"",
    "build": "vite build",
    "server": "node --experimental-sqlite server/index.js",
    "start": "npm run build && npm run server",
    "seed": "node --experimental-sqlite server/db/seed.js"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dom-to-image-more": "^3.7.2",
    "express": "^4.18.2",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "concurrently": "^8.2.2",
    "vite": "^5.1.4",
    "vue": "^3.4.19"
  }
}
